{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resume Data Schema",
  "type": "object",
  "required": ["version", "personalInfo"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "personalInfo": {
      "type": "object",
      "required": ["name", "contact", "links"],
      "properties": {
        "name": { "type": "string" },
        "contact": {
          "type": "object",
          "required": ["phone", "email"],
          "properties": {
            "phone": { "type": "string" },
            "email": { "type": "string", "format": "email" }
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "display"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "display": { "type": "string" }
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution", "location", "degree", "dates"],
        "properties": {
          "institution": { "type": "string" },
          "location": { "type": "string" },
          "degree": { "type": "string" },
          "dates": { "$ref": "#/$defs/dateRange" },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "employment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["organization", "location", "positions"],
        "properties": {
          "organization": { "type": "string" },
          "location": { "type": "string" },
          "positions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["position", "dates", "details"],
              "properties": {
                "position": { "type": "string" },
                "dates": { "$ref": "#/$defs/dateRangeExact" },
                "details": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "publications": {
      "type": "array",
      "items": { "type": "string" }
    },
    "funding": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["amount", "title", "date"],
        "properties": {
          "amount": { "type": "string" },
          "title": { "type": "string" },
          "date": { "$ref": "#/$defs/dateString" }
        }
      }
    },
    "service": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "details"],
        "properties": {
          "title": { "type": "string" },
          "details": { "type": "string" },
          "hidden": { "type": "boolean" }
        }
      }
    },
    "honors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "date"],
        "properties": {
          "title": { "type": "string" },
          "date": {
            "oneOf": [
              { "$ref": "#/$defs/dateString" },
              { "$ref": "#/$defs/dateRangeExact" }
            ]
          },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          },
          "hidden": { "type": "boolean" }
        }
      }
    },
    "talks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "date", "location"],
        "properties": {
          "title": { "type": "string" },
          "date": { "$ref": "#/$defs/dateString" },
          "location": { "type": "string" }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "dates", "skills", "links", "details"],
        "properties": {
          "title": { "type": "string" },
          "dates": { "$ref": "#/$defs/dateRangeExact" },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "display"],
              "properties": {
                "url": { "type": "string" },
                "display": { "type": "string" }
              }
            }
          },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          },
          "hidden": { "type": "boolean" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "dateString": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "dateOrNull": {
      "oneOf": [
        { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        { "type": "null" }
      ]
    },
    "dateRange": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/dateString" }
    },
    "dateRangeExact": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/dateOrNull" }
    }
  }
}
